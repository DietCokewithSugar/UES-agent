# ============================================================
# 环境变量示例文件
# ------------------------------------------------------------
# 使用方法：
#   1. 复制本文件为 .env.local（注意是 .env.local，不是 .env）：
#        cp .env.example .env.local
#   2. 把下面占位符替换成你自己的真实 Key
#   3. 重新启动开发服务：npm run dev
#
# 安全提示：
#   - .env.local 已被 .gitignore 忽略，不会被提交
#   - 千万不要把真实 Key 写在 .env.example 里
#   - 这些 Key 会在浏览器端直接调用第三方 API，请使用你能接受
#     "暴露在前端" 的 Key（例如做了用量上限的子账号 Key）
# ============================================================


# ------------------------------------------------------------
# Google Gemini （用于"AI 用户体验评测"主流程）
# ------------------------------------------------------------
# 获取地址：https://aistudio.google.com/app/apikey
# 形如：AIzaSy******************************
GEMINI_API_KEY=your_gemini_api_key_here


# ------------------------------------------------------------
# OpenRouter （可选；如果只用 Google Provider，可留空）
# ------------------------------------------------------------
# 获取地址：https://openrouter.ai/keys
# 形如：sk-or-v1-************************************************
OPENROUTER_API_KEY=


# ------------------------------------------------------------
# DeepSeek （用于"AI 体验伙伴"功能）
# ------------------------------------------------------------
# 1. 打开 DeepSeek 开放平台：https://platform.deepseek.com/
# 2. 注册/登录账号（支持手机号、微信、Google 登录）
# 3. 充值少量额度（DeepSeek 价格很低，1 元就够调试很久）
# 4. 左侧菜单 → "API Keys" → "创建 API Key"
#    （官方文档：https://api-docs.deepseek.com/zh-cn/）
# 5. 生成后立即复制（页面只显示一次），形如：
#        sk-************************************
# 6. 粘贴到下面的等号后面，不要带引号、不要带空格
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# DeepSeek API Base URL（可选）
# - 默认值即官方地址，无特殊需要不用改
# - 如果你的网络访问 api.deepseek.com 不稳定，可改成自建代理
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
